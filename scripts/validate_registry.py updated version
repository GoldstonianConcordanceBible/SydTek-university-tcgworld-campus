import json
from pathlib import Path


def load_json(path: Path):
    with path.open("r", encoding="utf-8") as f:
        return json.load(f)


def validate_required_fields(data, required_fields, label):
    missing = [field for field in required_fields if field not in data]
    if missing:
        print(f"[FAIL] {label} missing fields: {', '.join(missing)}")
        return False
    print(f"[OK] {label} contains required fields.")
    return True


def main():
    base = Path(__file__).resolve().parent.parent / "registry"

    files_and_requirements = [
        (
            base / "student-record-example.json",
            [
                "student_id",
                "name",
                "pathway",
                "status",
                "watch_hours_completed",
                "books_completed",
                "reflections_completed",
                "projects_completed",
                "last_updated",
            ],
            "student record",
        ),
        (
            base / "course-record-example.json",
            [
                "course_id",
                "title",
                "pathway",
                "playlist_hours_required",
                "books_required",
                "reflections_required",
                "final_assessment_required",
                "level",
                "status",
            ],
            "course record",
        ),
        (
            base / "program-record-example.json",
            [
                "program_id",
                "title",
                "institution",
                "track_type",
                "playlist_hours_required",
                "books_required",
                "reflections_required",
                "projects_required",
                "final_assessment_required",
                "public_claim_level",
                "status",
                "version",
                "last_updated",
            ],
            "program record",
        ),
    ]

    results = []
    for path, required_fields, label in files_and_requirements:
        data = load_json(path)
        results.append(validate_required_fields(data, required_fields, label))

    if all(results):
        print("Validation complete: all registry examples passed.")
    else:
        raise SystemExit("Validation failed.")


if __name__ == "__main__":
    main()